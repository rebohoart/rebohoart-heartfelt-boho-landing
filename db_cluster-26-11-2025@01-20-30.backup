-- Name: custom_orders Anyone can create custom orders; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Anyone can create custom orders" ON public.custom_orders FOR INSERT WITH CHECK (true);


--
-- Name: orders Anyone can create orders; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Anyone can create orders" ON public.orders FOR INSERT WITH CHECK (true);


--
-- Name: logos Anyone can read logos; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Anyone can read logos" ON public.logos FOR SELECT USING (true);


--
-- Name: site_settings Anyone can view site settings; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Anyone can view site settings" ON public.site_settings FOR SELECT USING (true);


--
-- Name: logos Authenticated users can delete logos; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Authenticated users can delete logos" ON public.logos FOR DELETE TO authenticated USING (true);


--
-- Name: logos Authenticated users can insert logos; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Authenticated users can insert logos" ON public.logos FOR INSERT TO authenticated WITH CHECK (true);


